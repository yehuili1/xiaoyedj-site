<UserControl x:Class="AutoMacro.Views.ActionListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d">

    <Grid Margin="16,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="动作脚本"
                       FontSize="18"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Foreground="White" />

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <ui:Button Icon="{ui:SymbolIcon Add24}"
                           ToolTip="添加延迟"
                           Command="{Binding AddActionCommand}"
                           Margin="0,0,4,0" />
                <ui:Button Content="图片点击"
                           Command="{Binding AddImageClickCommand}"
                           Margin="0,0,4,0" />
                <ui:Button Content="等图片"
                           Command="{Binding AddWaitImageCommand}"
                           Margin="0,0,4,0" />
                <ui:Button Content="等窗口"
                           Command="{Binding AddWaitWindowCommand}"
                           Margin="0,0,4,0" />
                <ui:Button Content="激活窗口"
                           Command="{Binding AddActivateWindowCommand}"
                           Margin="0,0,10,0" />
                <ui:Button Icon="{ui:SymbolIcon Delete24}"
                           ToolTip="删除"
                           Command="{Binding DeleteActionCommand}"
                           Margin="0,0,4,0" />
                <ui:Button Icon="{ui:SymbolIcon ArrowUp24}"
                           ToolTip="上移"
                           Command="{Binding MoveUpCommand}"
                           Margin="0,0,4,0" />
                <ui:Button Icon="{ui:SymbolIcon ArrowDown24}"
                           ToolTip="下移"
                           Command="{Binding MoveDownCommand}"
                           Margin="0,0,4,0" />
                <ui:Button Icon="{ui:SymbolIcon DismissCircle24}"
                           ToolTip="清空所有动作"
                           Content="清空"
                           Command="{Binding ClearAllCommand}"
                           Appearance="Danger"
                           Margin="0,0,10,0" />
                <ui:Button Icon="{ui:SymbolIcon Save24}"
                           Content="保存"
                           Command="{Binding SaveActionsCommand}"
                           Appearance="Primary" />
            </StackPanel>
        </Grid>

        <!-- Action DataGrid -->
        <DataGrid Grid.Row="1"
                  x:Name="ActionDataGrid"
                  ItemsSource="{Binding Actions}"
                  SelectedItem="{Binding SelectedAction}"
                  SelectedIndex="{Binding SelectedIndex}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  RowHeaderWidth="50"
                  LoadingRow="ActionDataGrid_LoadingRow"
                  AlternatingRowBackground="{DynamicResource ControlFillColorDefaultBrush}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="延迟(ms)"
                                    Width="100"
                                    Binding="{Binding DeltaMs}" />
                <DataGridTextColumn Header="类型"
                                    Width="120"
                                    Binding="{Binding EventType}" />
                <DataGridTextColumn Header="详情"
                                    Width="*"
                                    Binding="{Binding Details}" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
