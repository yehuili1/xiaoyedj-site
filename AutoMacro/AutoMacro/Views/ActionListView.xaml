<UserControl x:Class="AutoMacro.Views.ActionListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d">

    <Grid Margin="16,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="脚本步骤"
                       FontSize="18"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="0,0,0,8"
                       Foreground="White" />

            <WrapPanel Grid.Row="1"
                       Orientation="Horizontal"
                       HorizontalAlignment="Left">
                <ui:Button Content="插入录制"
                           ToolTip="录一段鼠标键盘动作，插入到当前选中步骤后面"
                           Command="{Binding InsertRecordingCommand}"
                           Margin="0,0,4,0" />
                <ui:Button Content="按键操作"
                           ToolTip="点击后按下要执行的按键，自动识别"
                           Command="{Binding AddKeyComboCommand}"
                           Margin="0,0,4,0" />
                <ui:Button Content="插入文字"
                           ToolTip="提前填写要粘贴的文字，执行时自动粘贴"
                           Command="{Binding AddPasteTextCommand}"
                           Margin="0,0,4,0" />
                <ui:Button Content="看到图片就点击"
                           Command="{Binding AddImageClickCommand}"
                           Margin="0,0,4,0" />
                <ui:Button Content="测试一下"
                           ToolTip="测试选中的图片或文字步骤"
                           Command="{Binding TestSelectedStepCommand}"
                           Margin="0,0,4,0" />
                <ui:Button Icon="{ui:SymbolIcon DismissCircle24}"
                           ToolTip="清空所有步骤"
                           Content="清空"
                           Command="{Binding ClearAllCommand}"
                           Appearance="Danger"
                           Margin="0,0,10,0" />
                <ui:Button Icon="{ui:SymbolIcon Save24}"
                           Content="全局保存"
                           ToolTip="保存当前方案设置和脚本步骤"
                           Command="{Binding SaveActionsCommand}"
                           Appearance="Primary" />
            </WrapPanel>
        </Grid>

        <!-- Action DataGrid -->
        <Grid Grid.Row="1"
              x:Name="ActionGridHost"
              ClipToBounds="True">
            <DataGrid x:Name="ActionDataGrid"
                  ItemsSource="{Binding Actions}"
                  SelectedItem="{Binding SelectedAction}"
                  SelectedIndex="{Binding SelectedIndex}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  RowHeaderWidth="0"
                  LoadingRow="ActionDataGrid_LoadingRow"
                  PreviewMouseLeftButtonDown="ActionDataGrid_PreviewMouseLeftButtonDown"
                  PreviewMouseMove="ActionDataGrid_PreviewMouseMove"
                  PreviewMouseLeftButtonUp="ActionDataGrid_PreviewMouseLeftButtonUp"
                  LostMouseCapture="ActionDataGrid_LostMouseCapture"
                  AlternatingRowBackground="{DynamicResource ControlFillColorDefaultBrush}">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="序号"
                                            Width="56">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Header, RelativeSource={RelativeSource AncestorType=DataGridRow}}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="图片"
                                            Width="88">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Padding="0"
                                        Width="72"
                                        Height="46"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Click="PreviewImage_Click"
                                        Visibility="{Binding HasImage, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Border Width="72"
                                            Height="46"
                                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                                            ClipToBounds="True">
                                        <Image Width="70"
                                               Height="44"
                                               Stretch="Uniform"
                                               SnapsToDevicePixels="True"
                                               Source="{Binding ImagePath}" />
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="动作"
                                        Width="120"
                                        Binding="{Binding ActionName}" />
                    <DataGridTemplateColumn Header="延迟时间"
                                            Width="96">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="{Binding AfterFoundDelayDisplayText}"
                                        MinWidth="66"
                                        Height="30"
                                        Padding="8,2"
                                        HorizontalAlignment="Center"
                                        Cursor="Hand"
                                        ToolTip="点击修改延迟时间"
                                        Command="{Binding DataContext.EditAfterFoundDelayCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Visibility="{Binding CanEditAfterFoundDelay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="超时时间"
                                            Width="96">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="{Binding TimeoutText}"
                                        MinWidth="66"
                                        Height="30"
                                        Padding="8,2"
                                        HorizontalAlignment="Center"
                                        Cursor="Hand"
                                        ToolTip="点击修改超时时间"
                                        Command="{Binding DataContext.EditTimeoutCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Visibility="{Binding CanEditTimeout, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
            <Border x:Name="DropIndicator"
                    Height="2"
                    Background="#4CC2FF"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top"
                    Visibility="Collapsed"
                    IsHitTestVisible="False"
                    Panel.ZIndex="10" />
        </Grid>
    </Grid>
</UserControl>
