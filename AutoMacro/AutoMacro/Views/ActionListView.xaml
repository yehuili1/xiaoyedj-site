<UserControl x:Class="AutoMacro.Views.ActionListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d">

    <Grid Margin="16,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="脚本步骤"
                       FontSize="18"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="0,0,0,8"
                       Foreground="White" />

            <WrapPanel Grid.Row="1"
                       Orientation="Horizontal"
                       HorizontalAlignment="Left">
                <ui:Button Icon="{ui:SymbolIcon Add24}"
                           ToolTip="添加等待"
                           Command="{Binding AddActionCommand}"
                           Margin="0,0,4,0" />
                <ui:Button Content="按键操作"
                           ToolTip="点击后按下要执行的按键，自动识别"
                           Command="{Binding AddKeyComboCommand}"
                           Margin="0,0,4,0" />
                <ui:Button Content="看到图片就点击"
                           Command="{Binding AddImageClickCommand}"
                           Margin="0,0,4,0" />
                <ui:Button Content="等待图片出现"
                           Command="{Binding AddWaitImageCommand}"
                           Margin="0,0,4,0" />
                <ui:Button Content="等待文字出现"
                           Command="{Binding AddWaitTextCommand}"
                           Margin="0,0,4,0" />
                <ui:Button Content="看到文字就点击"
                           Command="{Binding AddClickTextCommand}"
                           Margin="0,0,4,0" />
                <ui:Button Content="识别文字"
                           Command="{Binding AddReadTextCommand}"
                           Margin="0,0,4,0" />
                <ui:Button Content="框选区域"
                           ToolTip="给选中的文字识别步骤框选识别范围"
                           Command="{Binding PickOcrRegionCommand}"
                           Margin="0,0,4,0" />
                <ui:Button Content="读取数据"
                           Command="{Binding AddReadDataCommand}"
                           Margin="0,0,4,0" />
                <ui:Button Content="提交结果"
                           Command="{Binding AddSubmitDataCommand}"
                           Margin="0,0,4,0" />
                <ui:Button Content="完成后通知"
                           Command="{Binding AddNotifyCommand}"
                           Margin="0,0,4,0" />
                <ui:Button Content="测试一下"
                           ToolTip="测试选中的图片或文字步骤"
                           Command="{Binding TestSelectedStepCommand}"
                           Margin="0,0,4,0" />
                <ui:Button Content="时间设置"
                           ToolTip="设置最长等待时间和延迟执行时间"
                           Command="{Binding SetStepTimeCommand}"
                           Margin="0,0,4,0" />
                <ui:Button Content="等待窗口"
                           Command="{Binding AddWaitWindowCommand}"
                           Margin="0,0,4,0" />
                <ui:Button Content="切换到窗口"
                           Command="{Binding AddActivateWindowCommand}"
                           Margin="0,0,10,0" />
                <ui:Button Icon="{ui:SymbolIcon Delete24}"
                           ToolTip="删除"
                           Command="{Binding DeleteActionCommand}"
                           Margin="0,0,4,0" />
                <ui:Button Icon="{ui:SymbolIcon ArrowUp24}"
                           ToolTip="上移"
                           Command="{Binding MoveUpCommand}"
                           Margin="0,0,4,0" />
                <ui:Button Icon="{ui:SymbolIcon ArrowDown24}"
                           ToolTip="下移"
                           Command="{Binding MoveDownCommand}"
                           Margin="0,0,4,0" />
                <ui:Button Icon="{ui:SymbolIcon DismissCircle24}"
                           ToolTip="清空所有步骤"
                           Content="清空"
                           Command="{Binding ClearAllCommand}"
                           Appearance="Danger"
                           Margin="0,0,10,0" />
                <ui:Button Icon="{ui:SymbolIcon Save24}"
                           Content="全局保存"
                           ToolTip="保存当前方案设置和脚本步骤"
                           Command="{Binding SaveActionsCommand}"
                           Appearance="Primary" />
            </WrapPanel>
        </Grid>

        <!-- Action DataGrid -->
        <DataGrid Grid.Row="1"
                  x:Name="ActionDataGrid"
                  ItemsSource="{Binding Actions}"
                  SelectedItem="{Binding SelectedAction}"
                  SelectedIndex="{Binding SelectedIndex}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  RowHeaderWidth="50"
                  LoadingRow="ActionDataGrid_LoadingRow"
                  AlternatingRowBackground="{DynamicResource ControlFillColorDefaultBrush}">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="图片"
                                        Width="88">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Padding="0"
                                    Width="72"
                                    Height="46"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="PreviewImage_Click"
                                    Visibility="{Binding HasImage, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Border Width="72"
                                        Height="46"
                                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        ClipToBounds="True">
                                    <Image Width="70"
                                           Height="44"
                                           Stretch="Uniform"
                                           SnapsToDevicePixels="True"
                                           Source="{Binding ImagePath}" />
                                </Border>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="动作"
                                    Width="120"
                                    Binding="{Binding ActionName}" />
                <DataGridTemplateColumn Header="延迟时间"
                                        Width="96">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="{Binding AfterFoundDelayDisplayText}"
                                    MinWidth="66"
                                    Height="30"
                                    Padding="8,2"
                                    HorizontalAlignment="Center"
                                    Cursor="Hand"
                                    ToolTip="点击修改延迟时间"
                                    Command="{Binding DataContext.EditAfterFoundDelayCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    Visibility="{Binding CanEditAfterFoundDelay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="超时时间"
                                        Width="96">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="{Binding TimeoutText}"
                                    MinWidth="66"
                                    Height="30"
                                    Padding="8,2"
                                    HorizontalAlignment="Center"
                                    Cursor="Hand"
                                    ToolTip="点击修改超时时间"
                                    Command="{Binding DataContext.EditTimeoutCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    Visibility="{Binding CanEditTimeout, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
