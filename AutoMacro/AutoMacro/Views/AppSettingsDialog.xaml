<ui:FluentWindow
    x:Class="AutoMacro.Views.AppSettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="软件设置"
    Width="420"
    Height="360"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner"
    ExtendsContentIntoTitleBar="True"
    Icon="/Assets/icon.ico">

    <Grid Margin="20,40,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="软件设置"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="White"
                   Margin="0,0,0,14" />

        <StackPanel Grid.Row="1" Margin="0,0,0,18">
            <TextBlock Text="关闭软件时"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="White"
                       Margin="0,0,0,8" />
            <RadioButton x:Name="RbAsk"
                         Content="每次都询问"
                         Foreground="White"
                         Margin="0,0,0,8" />
            <RadioButton x:Name="RbExit"
                         Content="直接彻底退出软件"
                         Foreground="White"
                         Margin="0,0,0,8" />
            <RadioButton x:Name="RbMinimize"
                         Content="直接最小化到系统托盘"
                         Foreground="White" />
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,18">
            <TextBlock Text="启动设置"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="White"
                       Margin="0,0,0,8" />
            <CheckBox x:Name="CbStartWithWindows"
                      Content="开机自动启动"
                      Foreground="White" />
        </StackPanel>

        <TextBlock Grid.Row="3"
                   Text="这里可以改回关闭提示，也可以设置开机自动启动。"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <ui:Button Content="取消"
                       MinWidth="80"
                       Margin="0,0,8,0"
                       Click="Cancel_Click" />
            <ui:Button Content="保存"
                       MinWidth="80"
                       Appearance="Primary"
                       Click="Save_Click" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
