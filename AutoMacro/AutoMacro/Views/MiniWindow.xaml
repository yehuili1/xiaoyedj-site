<Window x:Class="AutoMacro.Views.MiniWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="全能脚本V2.2.1"
        Width="380" Height="72"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        ToolTip="双击恢复主窗口">

    <Border Background="#E0202020"
            CornerRadius="8"
            BorderBrush="#60FFFFFF"
            BorderThickness="1"
            Padding="10,6">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 状态指示灯 -->
            <Ellipse Grid.Column="0" Width="10" Height="10" Margin="0,0,8,0">
                <Ellipse.Style>
                    <Style TargetType="Ellipse">
                        <Setter Property="Fill" Value="#4CAF50" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                <Setter Property="Fill" Value="#F44336" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                <Setter Property="Fill" Value="#2196F3" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Ellipse.Style>
            </Ellipse>

            <!-- 当前步骤预览 -->
            <Border Grid.Column="1"
                    Width="54"
                    Height="42"
                    Margin="0,0,10,0"
                    Background="#2AFFFFFF"
                    BorderBrush="#35FFFFFF"
                    BorderThickness="1"
                    CornerRadius="4">
                <Grid ClipToBounds="True">
                    <Image Source="{Binding CurrentStepImagePath}"
                           Stretch="Uniform"
                           Visibility="{Binding CurrentStepHasImage, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <TextBlock Text="{Binding CurrentStepBadgeText}"
                               Foreground="White"
                               FontSize="12"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               MaxWidth="48">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentStepHasImage}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- 方案名 + 当前步骤 -->
            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,10,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding SelectedProfile.Name}"
                               Foreground="#AAAAAA"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="90"
                               Margin="0,0,6,0" />
                    <TextBlock Text="|" Foreground="#555555" FontSize="11" Margin="0,0,6,0" />
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="#DDDDDD"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <TextBlock Text="{Binding CurrentStepText}"
                           Foreground="White"
                           FontSize="12"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="250" />
                <TextBlock Text="{Binding CurrentStepDetail}"
                           Foreground="#BBBBBB"
                           FontSize="11"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="250" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
