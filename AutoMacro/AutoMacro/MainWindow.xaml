<ui:FluentWindow
    x:Class="AutoMacro.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:views="clr-namespace:AutoMacro.Views"
    mc:Ignorable="d"
    Title="全能脚本V2.2.1"
    Width="1200" Height="750"
    MinWidth="900" MinHeight="600"
    WindowStartupLocation="CenterScreen"
    ExtendsContentIntoTitleBar="True"
    Icon="Assets/icon.ico">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== ROW 0: TITLE BAR ===== -->
        <ui:TitleBar Grid.Row="0" Title="全能脚本V2.2.1" />

        <!-- ===== ROW 1: LEFT NAV + CENTER WORK AREA ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" MinWidth="180" MaxWidth="320" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ===== LEFT PANEL: Project Navigator ===== -->
            <Border Grid.Column="0"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="0,0,1,0">
                <Grid Margin="12,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Profile Selector -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="当前方案"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="2,0,0,4" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding Profiles}"
                                      SelectedItem="{Binding SelectedProfile}"
                                      DisplayMemberPath="Name"
                                      Margin="0,0,6,0" />
                            <ui:Button Grid.Column="1"
                                       Icon="{ui:SymbolIcon Add24}"
                                       Command="{Binding NewProfileCommand}"
                                       ToolTip="新建方案"
                                       Appearance="Primary"
                                       Margin="0,0,2,0" />
                            <ui:Button Grid.Column="2"
                                       Icon="{ui:SymbolIcon Rename24}"
                                       Command="{Binding RenameProfileCommand}"
                                       ToolTip="重命名方案"
                                       Margin="0,0,2,0" />
                            <ui:Button Grid.Column="3"
                                       Icon="{ui:SymbolIcon Delete24}"
                                       Command="{Binding DeleteProfileCommand}"
                                       ToolTip="删除方案"
                                       Appearance="Danger" />
                        </Grid>
                    </StackPanel>

                    <!-- Loop Count (per profile) -->
                    <Grid Grid.Row="1" Margin="0,4,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="循环次数:"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   Margin="2,0,8,0" />
                        <ui:NumberBox Grid.Column="1"
                                      Value="{Binding LoopCount, Mode=TwoWay}"
                                      Minimum="0"
                                      Maximum="9999"
                                      SpinButtonPlacementMode="Hidden" />
                        <TextBlock Grid.Column="2"
                                   Text="(0=无限)"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="11"
                                   Margin="6,0,0,0" />
                    </Grid>

                    <!-- Playback Speed (per profile) -->
                    <Grid Grid.Row="2" Margin="0,4,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="播放速度:"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   Margin="2,0,8,0" />
                        <ui:NumberBox Grid.Column="1"
                                      Value="{Binding PlaybackSpeed, Mode=TwoWay}"
                                      Minimum="0.1"
                                      Maximum="10"
                                      SpinButtonPlacementMode="Hidden" />
                        <TextBlock Grid.Column="2"
                                   Text="x"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="12"
                                   Margin="6,0,0,0" />
                    </Grid>

                    <!-- Import / Export -->
                    <Grid Grid.Row="3" Margin="0,4,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ui:Button Grid.Column="0"
                                   Icon="{ui:SymbolIcon ArrowExportUp24}"
                                   Content="导出全局"
                                   Command="{Binding ExportProfileCommand}"
                                   HorizontalAlignment="Stretch"
                                   Margin="0,0,2,0" />
                        <ui:Button Grid.Column="1"
                                   Icon="{ui:SymbolIcon ArrowImport24}"
                                   Content="导入全局"
                                   Command="{Binding ImportProfileCommand}"
                                   HorizontalAlignment="Stretch"
                                   Margin="2,0,0,0" />
                    </Grid>

                    <Grid Grid.Row="4" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ui:Button Grid.Column="0"
                                   Icon="{ui:SymbolIcon Settings24}"
                                   Content="快捷键"
                                   Command="{Binding OpenHotkeySettingsCommand}"
                                   HorizontalAlignment="Stretch"
                                   Margin="0,0,2,0" />
                        <ui:Button Grid.Column="1"
                                   Icon="{ui:SymbolIcon Options24}"
                                   Content="设置"
                                   Click="AppSettings_Click"
                                   HorizontalAlignment="Stretch"
                                   Margin="2,0,2,0" />
                        <ui:Button Grid.Column="2"
                                   Icon="{ui:SymbolIcon DocumentBulletList24}"
                                   Content="日志"
                                   Command="{Binding OpenLogFolderCommand}"
                                   HorizontalAlignment="Stretch"
                                   Margin="2,0,0,0" />
                    </Grid>

                </Grid>
            </Border>

            <!-- GridSplitter -->
            <GridSplitter Grid.Column="1"
                          Width="3"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Background="Transparent" />

            <!-- ===== CENTER: Action List Editor ===== -->
            <views:ActionListView Grid.Column="2"
                                  DataContext="{Binding ActionListVm}" />
        </Grid>

        <!-- ===== ROW 2: BOTTOM CONTROL & STATUS BAR ===== -->
        <Border Grid.Row="2"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Left: Status Indicator -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Margin="0,0,10,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#4CAF50" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                        <Setter Property="Fill" Value="#F44336" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                        <Setter Property="Fill" Value="#2196F3" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusText}"
                               VerticalAlignment="Center"
                               FontSize="13" />
                </StackPanel>

                <!-- Right: Record / Pause / Play / Stop Buttons -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <ui:Button Command="{Binding ToggleRecordingCommand}"
                               Appearance="Danger"
                               Margin="0,0,4,0"
                               MinWidth="100">
                        <ui:Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding RecordButtonText}" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding HotkeyRecordText, StringFormat=' ({0})'}"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="11" VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:Button.Content>
                    </ui:Button>
                    <ui:Button Command="{Binding TogglePauseCommand}"
                               Margin="0,0,4,0"
                               MinWidth="90"
                               Visibility="{Binding ShowPauseButton, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ui:Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding PauseButtonText}" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding HotkeyPauseText, StringFormat=' ({0})'}"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="11" VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:Button.Content>
                    </ui:Button>
                    <ui:Button Command="{Binding TogglePlaybackCommand}"
                               Appearance="Primary"
                               Margin="0,0,4,0"
                               MinWidth="100">
                        <ui:Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding PlaybackButtonText}" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding HotkeyPlaybackText, StringFormat=' ({0})'}"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="11" VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:Button.Content>
                    </ui:Button>
                    <ui:Button Content="紧急停止"
                               Icon="{ui:SymbolIcon Dismiss24}"
                               Command="{Binding EmergencyStopCommand}"
                               Appearance="Caution"
                               ToolTip="{Binding HotkeyStopText, StringFormat='快捷键: {0}'}"
                               MinWidth="80" />
                    <ui:Button Icon="{ui:SymbolIcon ArrowMinimize24}"
                               Content="迷你"
                               Click="MiniMode_Click"
                               ToolTip="切换迷你模式"
                               Margin="4,0,0,0" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
